# Database
DATABASE_URL=postgresql+asyncpg://postgres:sombutooki%40123@db.mpzcobkmxogmphqxypzi.supabase.co:5432/postgres

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_PATH=./storage

# AI Models
WHISPERX_MODEL=large-v2
SBERT_MODEL=all-MiniLM-L6-v2
SPEAKER_SIMILARITY_THRESHOLD=0.85

# Security
SECRET_KEY=your-secret-key-change-in-production

# Email (for reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# App
APP_NAME=AI Call Intelligence
DEBUG=true

# ── Jitsi Meet Integration ──────────────────────────────────────────────────
# Domain of the Jitsi web container (without https://)
JITSI_DOMAIN=localhost:8000
# JWT auth (only needed when ENABLE_AUTH=1 in Jitsi config)
JITSI_APP_ID=
JITSI_APP_SECRET=
# Shared secret that Prosody sends in X-Webhook-Secret header
JITSI_WEBHOOK_SECRET=

# ── Jitsi Stack Environment (for docker-compose Jitsi services) ─────────────
JITSI_HTTP_PORT=8000
JITSI_HTTPS_PORT=8443
JITSI_PUBLIC_URL=http://localhost:8000
ENABLE_LETSENCRYPT=0
LETSENCRYPT_DOMAIN=localhost
LETSENCRYPT_EMAIL=admin@localhost
ENABLE_AUTH=0
ENABLE_GUESTS=1
ENABLE_JAAS_COMPONENTS=0
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi
# Generate random secrets: openssl rand -hex 32
JICOFO_COMPONENT_SECRET=changeme
JICOFO_AUTH_PASSWORD=changeme
JVB_AUTH_PASSWORD=changeme
JIBRI_RECORDER_PASSWORD=changeme
JIBRI_XMPP_PASSWORD=changeme
# Set to your public IP / internal IP (comma-separated for LAN + public)
JVB_ADVERTISE_IPS=127.0.0.1
JVB_PORT=10000
JVB_TCP_PORT=4443
JVB_TCP_HARVESTER_DISABLED=false
MAX_PARTICIPANTS=0
TZ=UTC
