# Environment Configuration for Meeting AI

# HuggingFace Token (Required for speaker diarization)
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Optional: Custom model cache directory
# MODEL_CACHE_DIR=./models

# Optional: Custom data directory
# DATA_DIR=./data

# Optional: Custom output directory  
# OUTPUT_DIR=./outputs

# Optional: Redis URL for background tasks (if using Redis/Celery)
# REDIS_URL=redis://localhost:6379/0

# Optional: Database URL (if adding persistence)
# DATABASE_URL=sqlite:///./meeting_ai.db

# Optional: Debug mode
# DEBUG=False

# Optional: CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Optional: Maximum file size in bytes (default: 2GB)
# MAX_FILE_SIZE=2147483648

# Optional: Default transcription model size
# DEFAULT_WHISPER_MODEL=medium

# Optional: Default summarization model
# DEFAULT_SUMMARY_MODEL=facebook/bart-large-cnn